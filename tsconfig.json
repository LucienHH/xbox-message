{
	"compilerOptions": {
		"target": "ES6",
		"moduleResolution": "Bundler",
		"module": "esnext",
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"sourceMap": false,
		"alwaysStrict": true,
		"removeComments": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noImplicitReturns": true,
		"noUnusedParameters": false,
		"skipLibCheck": false,
		"esModuleInterop": true,
		"declaration": true,
	},
	"include": [
		"./src/**/*"
	],
	"exclude": [
		"./node_modules"
	]
}